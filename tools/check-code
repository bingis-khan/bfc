#!/bin/sh

if [[ -z "$1" ]]; then
	echo 'instruction not specified!'
	exit 1
fi

set -e

echo "
bits 64
section .text
  global _start
_start:
	$1
	db 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba, 0xba

	; just in case, exit
	mov rax, 60        ; syscall: exit
	mov rdi, 0         ; status code: 0
	syscall
" > /tmp/checkasm.asm

nasm -f elf64 /tmp/checkasm.asm -o /tmp/checkasm.o
ld /tmp/checkasm.o -o /tmp/checkasm

echo 'q' | gdb -q -ex 'set disassembly-flavor intel' -ex 'starti' -ex 'x/i $pc' -ex 'x/20bx $pc'  /tmp/checkasm
